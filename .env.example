EXPO_PUBLIC_ANTHROPIC_API_KEY=sk-ant-your-api-key-here

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (remplacer par les clés LIVE en production)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
EXPO_PUBLIC_STRIPE_EDGE_URL=https://your-project.supabase.co/functions/v1/create-payment-intent

# ── AdMob (PRODUCTION) ─────────────────────────────────────────────────────
# 1. Créer compte sur https://admob.google.com
# 2. Créer une app iOS + Android dans AdMob
# 3. Créer unité "Rewarded" pour chaque plateforme
# 4. Coller les IDs ci-dessous
EXPO_PUBLIC_ADMOB_REWARDED_IOS=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
EXPO_PUBLIC_ADMOB_REWARDED_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX

# App ID AdMob (dans app.json sous expo.plugins react-native-google-mobile-ads)
EXPO_PUBLIC_ADMOB_APP_ID_IOS=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX
EXPO_PUBLIC_ADMOB_APP_ID_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX

# ── Resend (email noreply@nextlove.app) ────────────────────────────────────
# 1. Créer compte sur https://resend.com (gratuit : 3000 emails/mois)
# 2. Ajouter le domaine nextlove.app → copier les DNS records dans OVH
# 3. Créer une API key
# 4. Dans Supabase Dashboard → Auth → SMTP :
#    Host: smtp.resend.com | Port: 587 | User: resend | Pass: (clé ci-dessous)
RESEND_API_KEY=re_...
